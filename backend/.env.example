# amoCRM
AMOCRM_DOMAIN=your-subdomain.amocrm.ru
AMOCRM_CLIENT_ID=your-client-id
AMOCRM_CLIENT_SECRET=your-client-secret
AMOCRM_REDIRECT_URI=https://your-backend.com/auth/amocrm/callback
AMOCRM_ACCESS_TOKEN=your-access-token
AMOCRM_PIPELINE_ID=0

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ADMIN_ID=your-telegram-user-id

# Baserow
BASEROW_URL=https://api.baserow.io
BASEROW_TOKEN=your-baserow-token
BASEROW_LEADS_TABLE_ID=0
BASEROW_LOGS_TABLE_ID=0

# Backend
BACKEND_URL=https://your-backend.onrender.com
PORT=8000
