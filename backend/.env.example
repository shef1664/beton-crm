# amoCRM
AMOCRM_DOMAIN=your-subdomain
AMOCRM_ACCESS_TOKEN=your-long-lived-token
AMOCRM_PIPELINE_ID=10818570
# JSON object with status name -> amoCRM status id
# Example: {"new":123,"qualification":456,"hot_lead":789}
AMOCRM_PIPELINE_STATUSES_JSON=
# JSON object with lead field -> amoCRM custom field id
# Example: {"source_platform":111111,"source_channel":222222,"source_account":333333}
AMOCRM_CUSTOM_FIELD_IDS_JSON=
# JSON object with route bucket -> manager/login/team label
# Example: {"geo":"geo-team","marketplaces":"marketplace-team","messengers":"messenger-team","phone":"call-team","default":"sales-team"}
SALES_MANAGERS_JSON=
# JSON object with integration -> secret key for generic external webhooks
# Example: {"yandex_maps":"secret-1","2gis":"secret-2"}
INTEGRATION_KEYS_JSON=

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_ID=your-telegram-id

# Backend
API_SECRET_KEY=your-secret-key-change-this
BACKEND_URL=http://localhost:8000
PORT=8000
DEBUG=false

# ── Render (заполнить после деплоя) ──
# RENDER=true
# BACKEND_URL=https://beton-backend-kwa9.onrender.com
# PORT=10000
